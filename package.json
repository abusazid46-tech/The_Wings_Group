{
  "name": "the-wings-group-platform",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.12.3",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "db:generate": "pnpm --filter @the-wings/api db:generate",
    "db:migrate": "pnpm --filter @the-wings/api db:migrate",
    "db:studio": "pnpm --filter @the-wings/api db:studio"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@next/eslint-plugin-next": "^15.1.0",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "pnpm": "9.12.3",
    "turbo": "^2.3.3",
    "typescript-eslint": "^8.18.2",
    "typescript": "^5.7.2"
  }
}
